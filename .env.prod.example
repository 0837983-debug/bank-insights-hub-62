# Docker Compose production environment (copy to .env in project root)
# Usage: cp .env.prod.example .env

# Image tag for ayreon208/bank-insights-{backend,frontend}
TAG=latest

# Bundled PostgreSQL (default VPS deploy). For RDS: use COMPOSE_PROFILES=external-db
COMPOSE_PROFILES=local-postgres

# HTTP port exposed by nginx frontend
HTTP_PORT=80

# PostgreSQL — bundled postgres service (profile local-postgres)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bankdb_prod
DB_USER=bank_prod_user
DB_PASSWORD=change_me_prod_password

# Admin credentials for bootstrap (defaults to DB_USER/DB_PASSWORD when unset)
# DB_ADMIN_USER=bank_prod_user
# DB_ADMIN_PASSWORD=change_me_prod_password

# --- RDS / external database (replace bundled postgres) ---
# COMPOSE_PROFILES=external-db
# DB_HOST=your-rds-endpoint.amazonaws.com
# DB_PORT=5432
# DB_NAME=bankdb_prod
# DB_USER=bank_prod_user
# DB_PASSWORD=your_rds_password

# Bootstrap dataset overrides (optional)
# BALANCE_DATASET_FILE=capital_2025-01.csv
# FIN_RESULTS_DATASET_FILE=fin_results_2025-01.csv
