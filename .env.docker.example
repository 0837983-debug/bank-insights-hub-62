# Docker Compose dev environment (copy to .env in project root)
# Usage: cp .env.docker.example .env

# Activate full dev stack (postgres + backend + frontend)
COMPOSE_PROFILES=full

# PostgreSQL (postgres service)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bankdb_local
DB_USER=bank_local_user
DB_PASSWORD=bank_local_password

# Bootstrap script (db-bootstrap service / npm run bootstrap:local-db)
BOOTSTRAP_PORT=3001
BOOTSTRAP_API_URL=http://backend:3001

# Frontend (browser calls backend on host)
VITE_API_URL=http://localhost:3001/api

# Optional dataset overrides
# BALANCE_DATASET_FILE=capital_2025-01.csv
# FIN_RESULTS_DATASET_FILE=fin_results_2025-01.csv
